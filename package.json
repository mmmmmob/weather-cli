{
  "name": "weather-cli-ts",
  "version": "1.0.0",
  "description": "Simple Weather CLI with TypeScript",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "weather": "./dist/index.js"
  },
  "scripts": {
    "start": "npx tsc && node dist/index.js",
